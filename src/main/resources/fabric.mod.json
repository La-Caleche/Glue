{
    "schemaVersion": 1,
    "id": "glue",
    "version": "${version}",
    "name": "Glue",
    "description": "Yet Another Minecraft Library that contains usefull tools for Minecraft modding",
    "authors": [
        "Malo <malo@lacaleche.cc>",
        "Theo <theo@lacaleche.cc>"
    ],
    "contact": {
        "homepage": "https://lacaleche.cc",
        "sources": "https://gitlab.lacaleche.cc/loccamy/java/glue"
    },
    "icon": "assets/glue/icon.png",
